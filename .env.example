# Copy this file to `.env` and fill in the values.
# Important: do NOT commit secrets into your repository.

# Supabase project URL (found in Project Settings -> API)
SUPABASE_URL=

# Supabase anon or service role key. For server-side trusted operations use the service_role key,
# but keep it private and do NOT commit it. For public insert-only workflows you may use the anon key
# and configure RLS to allow inserts on the `contacts` table.
SUPABASE_KEY=
